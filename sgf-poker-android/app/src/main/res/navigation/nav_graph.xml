<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/gamesFragment">

    <fragment
        android:id="@+id/gamesFragment"
        android:name="com.sgf.poker.ui.games.GamesFragment"
        android:label="Games"
        tools:layout="@layout/fragment_games">

        <action
            android:id="@+id/actionGamesToDetail"
            app:destination="@id/gameDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/gameDetailFragment"
        android:name="com.sgf.poker.ui.gamedetail.GameDetailFragment"
        android:label="Game Detail"
        tools:layout="@layout/fragment_game_detail">

        <argument
            android:name="gameId"
            app:argType="string" />

        <action
            android:id="@+id/actionDetailToPrizes"
            app:destination="@id/prizesFragment" />
    </fragment>

    <fragment
        android:id="@+id/prizesFragment"
        android:name="com.sgf.poker.ui.prizes.PrizesFragment"
        android:label="Prizes"
        tools:layout="@layout/fragment_prizes">

        <argument
            android:name="gameId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/playersFragment"
        android:name="com.sgf.poker.ui.players.PlayersFragment"
        android:label="Players"
        tools:layout="@layout/fragment_players" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.sgf.poker.ui.common.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
